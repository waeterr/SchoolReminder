<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6FF"
    tools:context=".JoinClassActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#66A9D9"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="40dp"
            android:backgroundTint="#66A9D9">

            <!-- TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gabung Kelas"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="30sp"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"/>

            <!-- NAMA KELAS -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Kelas"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etNamaKelas"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@android:color/white"
                android:hint="Masukkan nama kelas"
                android:padding="16dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0"
                android:layout_marginBottom="24dp"/>

            <!-- KODE KELAS -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kode Kelas"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etKodeKelas"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@android:color/white"
                android:hint="Masukkan kode kelas"
                android:padding="16dp"
                android:textColor="#000000"
                android:textColorHint="#A0A0A0"
                android:layout_marginBottom="32dp"/>

            <!-- BUTTON -->

            <Button
                android:id="@+id/btnGabung"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="Gabung"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#173B73"
                android:layout_gravity="end"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>